{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    
    
        

    
        {
            "name": "🚀 Pepe Silv.AI (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_dev.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "main",
                "order": 1
            }
        },
        {
            "name": "🧪 Run Tests",
            "type": "debugpy", 
            "request": "launch",
            "program": "${workspaceFolder}/run_all_tests.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "test",
                "order": 2
            }
        },
        {
            "name": "🌿 Run Database Tests",
            "type": "debugpy", 
            "request": "launch",
            "program": "${workspaceFolder}/test_database_adapter.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "test",
                "order": 2
            }
        },
        {
            "name": "🧹 Cleanup Database Tests",
            "type": "debugpy", 
            "request": "launch",
            "program": "${workspaceFolder}/test_database_adapter.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": ["cleanup"],
            "cwd": "${workspaceFolder}",
            "presentation": {
                "hidden": false,
                "group": "test",
                "order": 2
            }
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "exceptionHandling": {
                "ignore": ["<Exception type>"],
                "break": {
                "uncaught": true,
                "userUnhandled": true
                }
            }
        },
        {
            "name": "Run test_edge_runner.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/test_edge_runner.py",
            "env": { "PYTHONPATH": "${workspaceFolder}/src" }
        }

    ],
    "compounds": [
        {
            "name": "🔥 Full System Debug",
            "configurations": [
                "🚀 Pepe Silv.AI (Debug)",
                "🧪 Run Tests"
            ],
            "stopAll": true,
            "presentation": {
                "hidden": false,
                "group": "compound",
                "order": 4
            }
        }
    ]
}